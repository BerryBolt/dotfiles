#!/bin/bash
# Install packages: mise tools first, then Homebrew for GUI apps/system deps

set -e

echo "Installing mise tools..."
mise install --yes

# Install Homebrew if not present (macOS)
BREW_BIN=""
if command -v brew &> /dev/null; then
    BREW_BIN="$(command -v brew)"
elif [[ -x /opt/homebrew/bin/brew ]]; then
    BREW_BIN="/opt/homebrew/bin/brew"
elif [[ -x /usr/local/bin/brew ]]; then
    BREW_BIN="/usr/local/bin/brew"
fi

if [[ -z "$BREW_BIN" ]]; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [[ -x /opt/homebrew/bin/brew ]]; then
        BREW_BIN="/opt/homebrew/bin/brew"
    elif [[ -x /usr/local/bin/brew ]]; then
        BREW_BIN="/usr/local/bin/brew"
    fi
fi

if [[ -n "$BREW_BIN" ]]; then
    eval "$("$BREW_BIN" shellenv)"
else
    echo "Warning: Homebrew not found; skipping Brewfile installs."
fi

echo "Installing Homebrew packages..."
BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile"

if [[ -f "$BREWFILE" ]]; then
    if [[ -z "$BREW_BIN" ]]; then
        echo "Warning: Homebrew not available; skipping Brewfile installs."
    else
        BREW_PREFIX="$("$BREW_BIN" --prefix)"
        if [[ ! -w "$BREW_PREFIX" && ! -w "$BREW_PREFIX/Cellar" ]]; then
            echo "Warning: Homebrew prefix $BREW_PREFIX is not writable; skipping Brewfile installs."
        else
            if "$BREW_BIN" bundle --help 2>&1 | grep -q -- '--no-lock'; then
                "$BREW_BIN" bundle --file="$BREWFILE" --no-lock
            else
                "$BREW_BIN" bundle --file="$BREWFILE"
            fi
        fi
    fi
else
    echo "Warning: Brewfile not found at $BREWFILE"
fi

echo "Package installation complete."
