#!/bin/bash
# Install packages: mise tools first, then Homebrew GUI apps/system deps.

set -euo pipefail

echo "Installing mise tools..."
mise install --yes

# Homebrew should already be installed by install.sh on macOS.
# Keep this lookup-only fallback for manual chezmoi apply runs.
BREW_BIN=""
if command -v brew &> /dev/null; then
    BREW_BIN="$(command -v brew)"
elif [[ -x /opt/homebrew/bin/brew ]]; then
    BREW_BIN="/opt/homebrew/bin/brew"
elif [[ -x /usr/local/bin/brew ]]; then
    BREW_BIN="/usr/local/bin/brew"
fi

if [[ -z "$BREW_BIN" ]]; then
    echo "Warning: Homebrew not found; skipping macOS Brewfile installs."
    echo "         Install Homebrew separately, then re-run: chezmoi apply"
fi

if [[ -n "$BREW_BIN" ]]; then
    eval "$("$BREW_BIN" shellenv)"
fi

echo "Installing Homebrew packages..."
BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile"

extract_brew_entries() {
    local kind=$1
    sed -nE "s/^[[:space:]]*${kind}[[:space:]]+\"([^\"]+)\".*/\\1/p" "$BREWFILE"
}

install_brew_formula() {
    local formula=$1
    if "$BREW_BIN" list --formula "$formula" >/dev/null 2>&1; then
        echo "Homebrew formula already installed: $formula"
        return
    fi

    echo "Installing Homebrew formula: $formula"
    "$BREW_BIN" install "$formula"
}

install_brew_cask() {
    local cask=$1
    if "$BREW_BIN" list --cask "$cask" >/dev/null 2>&1; then
        echo "Homebrew cask already installed: $cask"
        return
    fi

    echo "Installing Homebrew cask: $cask"
    "$BREW_BIN" install --cask "$cask"
}

if [[ -f "$BREWFILE" ]]; then
    if [[ -z "$BREW_BIN" ]]; then
        echo "Warning: Homebrew not available; skipping Brewfile installs."
    else
        BREW_PREFIX="$("$BREW_BIN" --prefix)"
        if [[ ! -w "$BREW_PREFIX" && ! -w "$BREW_PREFIX/Cellar" ]]; then
            echo "Warning: Homebrew prefix $BREW_PREFIX is not writable; skipping Brewfile installs."
        else
            while IFS= read -r tap; do
                [[ -n "$tap" ]] || continue
                echo "Ensuring Homebrew tap: $tap"
                "$BREW_BIN" tap "$tap"
            done < <(extract_brew_entries tap)

            while IFS= read -r formula; do
                [[ -n "$formula" ]] || continue
                install_brew_formula "$formula"
            done < <(extract_brew_entries brew)

            while IFS= read -r cask; do
                [[ -n "$cask" ]] || continue
                install_brew_cask "$cask"
            done < <(extract_brew_entries cask)
        fi
    fi
else
    echo "Warning: Brewfile not found at $BREWFILE"
fi

echo "Package installation complete."
