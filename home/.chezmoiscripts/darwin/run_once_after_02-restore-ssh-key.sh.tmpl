#!/bin/bash
# Restore SSH key from 1Password

set -e

# Ensure mise shims are in PATH (for op command)
export PATH="$HOME/.local/share/mise/shims:$PATH"

SSH_DIR="$HOME/.ssh"
SSH_KEY_NAME="id_ed25519"
SSH_KEY="$SSH_DIR/$SSH_KEY_NAME"
SSH_KEY_TMP="$SSH_KEY.tmp"

# Skip if key already exists
if [[ -f "$SSH_KEY" ]]; then
    echo "SSH key already exists, skipping..."
    exit 0
fi

echo "Restoring SSH key from 1Password..."

# Create .ssh directory if needed
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"

# Fetch private key from 1Password in OpenSSH format.
# 1Password may otherwise return a format that ssh-keygen rejects here.
if ! op read "op://{{ .op_vault }}/$SSH_KEY_NAME/private key?ssh-format=openssh" > "$SSH_KEY_TMP"; then
    rm -f "$SSH_KEY_TMP"
    echo "Error: missing required 1Password SSH key item."
    echo "Expected vault: {{ .op_vault }}"
    echo "Expected item title: $SSH_KEY_NAME"
    echo "Expected item type: SSH Key"
    echo "Expected field: private key"
    exit 1
fi
chmod 600 "$SSH_KEY_TMP"

# Validate the private key before moving it into place.
if ! ssh-keygen -y -f "$SSH_KEY_TMP" > "$SSH_KEY.pub"; then
    rm -f "$SSH_KEY_TMP" "$SSH_KEY.pub"
    echo "Error: restored SSH key is not a valid OpenSSH private key."
    exit 1
fi

mv "$SSH_KEY_TMP" "$SSH_KEY"
chmod 644 "$SSH_KEY.pub"

echo "SSH key restored successfully."

# Switch chezmoi repo to SSH remote (now that key exists)
REPO_DIR="$HOME/.local/share/chezmoi"
if [[ -d "$REPO_DIR/.git" ]]; then
    current="$(git -C "$REPO_DIR" remote get-url origin 2>/dev/null || true)"
    case "$current" in
        https://github.com/BerryBolt/dotfiles* )
            git -C "$REPO_DIR" remote set-url origin git@github.com:BerryBolt/dotfiles.git
            echo "Switched chezmoi remote to SSH."
            ;;
    esac
fi
